# ─── Supabase ──────────────────────────────────────────────────────────────
# Project Settings → API ใน Supabase Dashboard
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ─── Perenual Flower API (optional) ────────────────────────────────────────
# สมัครฟรีที่ https://perenual.com/api  (100 req/day)
VITE_PERENUAL_API_KEY=

# How to use:
# 1. เปลี่ยนชื่อไฟล์นี้เป็น .env.local
# 2. ใส่ค่า VITE_SUPABASE_URL และ VITE_SUPABASE_PUBLISHABLE_KEY จาก Supabase Dashboard
# 3. (ถ้าต้องการใช้ Perenual API) สมัครและใส่ค่า VITE_PERENUAL_API_KEY จาก Perenual API Dashboard
# 4. รันคำสั่ง `npm run dev` เพื่อเริ่มต้นโปรเจกต์